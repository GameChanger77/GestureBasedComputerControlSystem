{
  "version": 1,
  "global": {
    "default_pending_frames": 3,
    "default_ending_frames": 2
  },
  "custom_gestures": [
    {
      "id": "g_open_palm",
      "name": "Open Palm",
      "enabled": true,
      "mode": "mouse",
      "type": "pose",
      "priority": 8,
      "hand": "right",
      "conditions": [
        { "op": "only_fingers_extended", "fingers": ["index", "middle", "ring", "pinky"], "threshold_deg": 155 }
      ],
      "confirm": { "pending_frames": 3, "ending_frames": 2 },
      "action": { "type": "mouse_move", "params": { "at": "index.tip", "space": "camera" } }
    },
    {
      "id": "g_pinch_index_thumb",
      "name": "Index+Thumb Pinch",
      "enabled": true,
      "mode": "mouse",
      "type": "pose",
      "priority": 8,
      "hand": "right",
      "conditions": [
        { "op": "pinch_distance_lt", "a": "thumb.tip", "b": "index.tip", "value": 0.25, "space": "wrist" }
      ],
      "confirm": { "pending_frames": 1, "ending_frames": 2 },
      "action": { "type": "left_click", "params": { "at": "index.tip", "space": "camera" } }
    }
  ]
}
